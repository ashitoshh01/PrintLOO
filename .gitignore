# ============================================================
# PrintLOO Monorepo — .gitignore
# ============================================================

# --- Dependencies ---
node_modules/
**/node_modules/
.pnp
.pnp.*

# --- Environment files (NEVER commit secrets) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*
# Allow example env files
!.env.example

# --- Next.js build output ---
apps/web/.next/
apps/web/out/

# --- NestJS build output ---
apps/api/dist/

# --- Uploaded user files (runtime data, not source) ---
apps/api/uploads/

# --- TypeScript ---
*.tsbuildinfo
apps/web/next-env.d.ts

# --- Turborepo cache ---
.turbo/

# --- Testing ---
coverage/
.nyc_output/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
web_build.log

# --- OS & Editor ---
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Misc ---
.vercel
