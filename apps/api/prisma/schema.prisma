generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  OPERATOR
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  QUEUED
  PROCESSING
  PRINTING
  COMPLETED
  FAILED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model User {
  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  passwordHash String
  role         UserRole    @default(CUSTOMER)
  shopId       String?
  shop         Shop?       @relation(fields: [shopId], references: [id])
  orders       PrintOrder[]
  refreshTokens RefreshToken[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([email])
  @@index([shopId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model Shop {
  id          String      @id @default(uuid())
  name        String
  location    String
  contact     String
  isActive    Boolean     @default(true)
  settings    Json        @default("{}")
  users       User[]
  printers    Printer[]
  orders      PrintOrder[]
  pricingRules PricingRule[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Printer {
  id              String   @id @default(uuid())
  shopId          String
  shop            Shop     @relation(fields: [shopId], references: [id])
  name            String
  supportsColor   Boolean  @default(false)
  supportsDuplex  Boolean  @default(false)
  isOnline        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shopId])
}

model PricingRule {
  id        String  @id @default(uuid())
  shopId    String
  shop      Shop    @relation(fields: [shopId], references: [id])
  colorMode String
  sides     String
  pricePerPage Decimal @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shopId, colorMode, sides])
  @@index([shopId])
}

model PrintOrder {
  id              String      @id @default(uuid())
  shopId          String
  shop            Shop        @relation(fields: [shopId], references: [id])
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  fileUrl         String
  fileName        String
  pageCount       Int
  config          Json
  status          OrderStatus @default(PENDING)
  tokenNumber     Int
  estimatedMinutes Int        @default(0)
  totalAmount     Decimal     @db.Decimal(10, 2)
  payment         Payment?
  queueJob        QueueJob?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([shopId])
  @@index([userId])
  @@index([status])
}

model Payment {
  id                 String        @id @default(uuid())
  orderId            String        @unique
  order              PrintOrder    @relation(fields: [orderId], references: [id])
  razorpayOrderId    String        @unique
  razorpayPaymentId  String?
  razorpaySignature  String?
  amount             Decimal       @db.Decimal(10, 2)
  currency           String        @default("INR")
  status             PaymentStatus @default(PENDING)
  verifiedAt         DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([orderId])
  @@index([razorpayOrderId])
}

model QueueJob {
  id        String   @id @default(uuid())
  orderId   String   @unique
  order     PrintOrder @relation(fields: [orderId], references: [id])
  shopId    String
  position  Int
  status    String   @default("WAITING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([orderId])
}
