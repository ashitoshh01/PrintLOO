# ============================================================
# apps/api — NestJS .gitignore
# ============================================================

# --- Compiled output ---
dist/
build/

# --- Dependencies ---
node_modules/

# --- Uploaded user files (runtime data, not source code) ---
uploads/

# --- TypeScript ---
*.tsbuildinfo

# --- Turborepo cache ---
.turbo/

# --- Testing ---
coverage/
.nyc_output/

# --- Environment files ---
.env
.env.local
.env.test
.env.production
.env.*
!.env.example

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# --- OS ---
.DS_Store
Thumbs.db

# --- IDEs and editors ---
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# --- VSCode (allow shared workspace settings) ---
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
